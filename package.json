{
  "name": "legal-appointments-system",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-timezone legal appointment scheduling system.",
  "scripts": {
    "dev": "pnpm -r --parallel --stream --filter \"./apps/*\" dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "db:migrate": "pnpm --filter api exec prisma migrate dev",
    "db:seed": "pnpm --filter api exec tsx prisma/seed.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
